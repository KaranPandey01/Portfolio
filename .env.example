# ─────────────────────────────────────────────
#  Karan Portfolio — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to GitHub
# ─────────────────────────────────────────────

# Your Gmail address (the one you want to SEND FROM and RECEIVE AT)
GMAIL_USER=karanpandey569@gmail.com

# Gmail App Password — NOT your real Gmail password
# How to get it:
#   1. Go to myaccount.google.com
#   2. Security → 2-Step Verification (must be ON)
#   3. Security → App Passwords
#   4. Select "Mail" + "Other (custom name)" → type "Portfolio"
#   5. Copy the 16-character password and paste it below (no spaces)
GMAIL_PASS=your_16_char_app_password_here

